{
  "name": "wheellive",
  "version": "0.1.0",
  "private": true,
  "description": "Professional wheel-of-prizes system for TikTok Live streams",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "node packages/backend/dist/main.js",
    "live": "pnpm build && pnpm start",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "docker:backup": "mkdir -p backups && docker compose exec db pg_dump -U wheellive wheellive > backups/wheellive-$(date +%Y%m%dT%H%M%S).sql"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0"
  }
}
